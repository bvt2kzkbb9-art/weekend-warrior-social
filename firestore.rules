rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper function ─────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── Users ───────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
                    || (isAuth() && request.resource.data.diff(resource.data)
                        .affectedKeys().hasOnly(['points','level','rank',
                        'challengesCompleted','challengesSent','postsCount',
                        'streak','lastActive','achievements','badges']));
    }

    // ── Posts ───────────────────────────────────────────────────
    match /posts/{postId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuth()
                    && (resource.data.authorId == request.auth.uid
                        || request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['likes','likesCount','reactions','reactionsCount',
                                     'commentsCount','sharesCount']));
      allow delete: if isAuth() && resource.data.authorId == request.auth.uid;
    }

    // ── Comments ────────────────────────────────────────────────
    match /posts/{postId}/comments/{commentId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.authorId == request.auth.uid;
      allow delete: if isAuth() && resource.data.authorId == request.auth.uid;
      allow update: if false;
    }

    // ── Followers ───────────────────────────────────────────────
    match /followers/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuth() && resource.data.followerId == request.auth.uid;
      allow update: if isAuth();
    }

    // ── Friends system ──────────────────────────────────────────
    match /friend_requests/{docId} {
      allow read:   if isAuth()
                    && (resource.data.senderId   == request.auth.uid
                        || resource.data.receiverId == request.auth.uid);
      allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuth()
                    && (resource.data.senderId   == request.auth.uid
                        || resource.data.receiverId == request.auth.uid);
      allow delete: if isAuth() && resource.data.senderId == request.auth.uid;
    }

    match /friends/{docId} {
      allow read:   if isAuth()
                    && (resource.data.uid1 == request.auth.uid
                        || resource.data.uid2 == request.auth.uid);
      allow create: if isAuth();
      allow delete: if isAuth()
                    && (resource.data.uid1 == request.auth.uid
                        || resource.data.uid2 == request.auth.uid);
    }

    // ── Notifications ───────────────────────────────────────────
    match /notifications/{uid}/items/{notifId} {
      allow read:   if isOwner(uid);
      allow create: if isAuth();
      allow update: if isOwner(uid);
      allow delete: if isOwner(uid);
    }

    // ── Conversations (Messenger) ───────────────────────────────
    match /conversations/{convId} {
      allow read:   if isAuth()
                    && request.auth.uid in resource.data.participants;
      allow create: if isAuth()
                    && request.auth.uid in request.resource.data.participants;
      allow update: if isAuth()
                    && request.auth.uid in resource.data.participants;
    }

    // ── Messages ────────────────────────────────────────────────
    match /conversations/{convId}/messages/{msgId} {
      allow read:   if isAuth()
                    && request.auth.uid in
                       get(/databases/$(database)/documents/conversations/$(convId))
                       .data.participants;
      allow create: if isAuth()
                    && request.resource.data.senderId == request.auth.uid
                    && request.auth.uid in
                       get(/databases/$(database)/documents/conversations/$(convId))
                       .data.participants;
      allow update: if isAuth()
                    && resource.data.senderId == request.auth.uid;
    }

    // ── Challenge Invites ───────────────────────────────────────
    match /challenge_invites/{docId} {
      allow read:   if isAuth()
                    && (resource.data.challengerId == request.auth.uid
                        || resource.data.targetId   == request.auth.uid);
      allow create: if isAuth()
                    && request.resource.data.challengerId == request.auth.uid;
      allow update: if isAuth()
                    && (resource.data.challengerId == request.auth.uid
                        || resource.data.targetId   == request.auth.uid);
    }

    // ── Challenge Completions ───────────────────────────────────
    match /challenge_completions/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // ── Challenge Quizzes ───────────────────────────────────────
    match /challenge_quizzes/{docId} {
      allow read:   if isAuth()
                    && (resource.data.userId == request.auth.uid
                        || resource.data.inviteId in ['']);
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── User Challenges ─────────────────────────────────────────
    match /userChallenges/{docId} {
      allow read:   if isAuth();
      allow write:  if isAuth();
    }

    // ── Duels ───────────────────────────────────────────────────
    match /duels/{docId} {
      allow read:   if isAuth()
                    && (resource.data.challengerId == request.auth.uid
                        || resource.data.targetId   == request.auth.uid);
      allow create: if isAuth();
      allow update: if isAuth()
                    && (resource.data.challengerId == request.auth.uid
                        || resource.data.targetId   == request.auth.uid);
    }

    // ── Pokes ───────────────────────────────────────────────────
    match /pokes/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.pokerId == request.auth.uid;
    }

    // ── Weekly Scores ───────────────────────────────────────────
    match /weeklyScores/{weekId}/scores/{uid} {
      allow read:  if isAuth();
      allow write: if isOwner(uid);
    }

    // ── Usernames (search/mention lookup) ──────────────────────
    match /usernames/{username} {
      allow read:  if isAuth();
      allow write: if isAuth() && request.resource.data.uid == request.auth.uid;
    }

    // ── Laga Pajacu ─────────────────────────────────────────────
    match /pajacChallenges/{docId} {
      allow read:   if isAuth()
                    && (resource.data.initiatorId == request.auth.uid
                        || resource.data.targetId   == request.auth.uid);
      allow create: if isAuth()
                    && request.resource.data.initiatorId == request.auth.uid;
      allow update: if isAuth()
                    && (resource.data.initiatorId == request.auth.uid
                        || resource.data.targetId   == request.auth.uid);
    }

    // ── Laga Events (feed) ──────────────────────────────────────
    match /laga_events/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth();
    }

    // ── Blocks ──────────────────────────────────────────────────
    match /blocks/{docId} {
      allow read:   if isAuth() && resource.data.blockerId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.blockerId == request.auth.uid;
      allow delete: if isAuth() && resource.data.blockerId == request.auth.uid;
    }

    // ── Reports ─────────────────────────────────────────────────
    match /reports/{docId} {
      allow create: if isAuth() && request.resource.data.reporterId == request.auth.uid;
      allow read:   if false;  // admin only via Admin SDK
    }

    // ── Shares ──────────────────────────────────────────────────
    match /shares/{docId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.sharerId == request.auth.uid;
    }
  }


